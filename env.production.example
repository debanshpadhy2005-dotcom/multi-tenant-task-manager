# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ========================================
# Copy this file and fill in your production values
# DO NOT commit the actual .env.production file!

# ========================================
# BACKEND CONFIGURATION
# ========================================

# Server
NODE_ENV=production
PORT=5000

# Database (Use DATABASE_URL for cloud deployment)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secrets (Generate strong 32+ character secrets)
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_STRONG_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (Your Vercel deployment URL)
FRONTEND_URL=https://your-app-name.vercel.app

# API Configuration
API_VERSION=v1
LOG_LEVEL=info

# ========================================
# FRONTEND CONFIGURATION
# ========================================

# API URL (Your Railway/Render backend URL)
VITE_API_URL=https://your-backend-name.railway.app/api/v1

# ========================================
# DEPLOYMENT PLATFORMS
# ========================================

# Railway: Automatically provides DATABASE_URL
# Render: Copy "Internal Database URL" from database settings
# Vercel: Only needs VITE_API_URL

# ========================================
# SECURITY NOTES
# ========================================

# 1. Generate JWT secrets using:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. Never commit .env files to Git
#
# 3. Use different secrets for development and production
#
# 4. Update FRONTEND_URL after deploying frontend
#
# 5. Update VITE_API_URL after deploying backend
